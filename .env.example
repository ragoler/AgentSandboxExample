# Mode of operation: MOCK (local simulation) or REAL (GKE Agent Sandbox)
MODE=MOCK

# Name of the GKE Gateway resource for Production mode
GATEWAY_NAME=external-http-gateway

# Name of the GKE cluster
CLUSTER_NAME=agent-sandbox-cluster

# Google Cloud Region
REGION=us-west1

# Google Cloud Project ID (Required for REAL mode)
PROJECT_NAME=YOUR_PROJECT_ID
